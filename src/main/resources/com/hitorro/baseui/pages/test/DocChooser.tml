This is a test
<t:form t:id="form">
<table t:type="grid" t:source="docs" t:row="doc" t:model="mymodel" t:rowsPerPage="8" t:pagerPosition="top">[Grid here]
    hello<t:parameter name="actionCell">
        <t:pagelink t:page="test/main" t:context="doc.guid">
            View
        </t:pagelink>
    </t:parameter>
</table>
