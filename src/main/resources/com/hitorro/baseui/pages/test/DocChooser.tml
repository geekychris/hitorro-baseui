        <div class="demo" id="droppable_container">
            <div t:id="dragme" t:type='any' class="dragbox" t:mixins="dragmixin">
               drag
            </div>
            <div t:id="dropme" t:type='any' t:mixins="dropmixin" class= "dropbox" t:dropClass="literal:dragbox">
               Drop on me away ada
            </div>
        </div>


